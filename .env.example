# ============================================================
# TechZone ERP — Environment Configuration
# ============================================================
# 1. Rename this file to: .env
# 2. Fill in your actual values
# 3. NEVER commit .env to GitHub
# ============================================================

# ── LOCAL PostgreSQL (for running locally) ──────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mini_erp_db
# DB_USER=postgres
# DB_PASSWORD=your_local_password

# ── NEON Cloud PostgreSQL (for deployment) ──────────────────
DB_HOST=ep-nameless-field-aq7rian0-pooler.c-8.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_neon_password_here

# ── AI Feature (Optional) ───────────────────────────────────
# Get key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
